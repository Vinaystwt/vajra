    "@solana/web3.js": "^1.98.4",
    "@types/node": "^25.6.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^3.8.3",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
