  "scripts": {
    "build": "cd packages/sdk && npm run build && cd ../mcp && npm run build",
    "test": "cargo test --manifest-path programs/vajra/Cargo.toml && cd packages/sdk && npm test && cd ../mcp && npm test",
    "demo:full": "ts-node scripts/full-demo.ts",
    "demo:attack": "ts-node scripts/attack-demo.ts",
    "demo:red-team": "npm run build && node scripts/red-team-sandbox.mjs",
    "demo:x402": "ts-node scripts/x402-demo.ts",
    "proof:export": "ts-node scripts/export-proof.ts",
    "proof:latest": "npm run build && node scripts/export-mandates.mjs && node scripts/generate-latest-proof.mjs",
    "verify:fixtures": "npm run build && node scripts/verify-fixtures.mjs",
    "verify:red-team": "npm run proof:latest && node scripts/verify-fixtures.mjs",
    "verify:tx": "npm run build && node scripts/verify-payment.mjs",
    "receipt:tx": "npm run build && node scripts/export-receipt.mjs",
    "mandates:list": "npm run build && node scripts/list-mandates.mjs",
    "mandate:show": "npm run build && node scripts/show-mandate.mjs",
    "check:devnet": "ts-node scripts/check-devnet-readiness.ts",
    "check:deployer": "ts-node scripts/check-deployer.ts",
    "devnet:setup": "ts-node scripts/devnet-setup.ts",
    "devnet:demo": "ts-node scripts/devnet-run-demo.ts",
    "devnet:proof": "ts-node scripts/devnet-proof.ts",
    "devnet:red-team": "npm run build && node scripts/devnet-red-team.mjs",
    "lint:fix": "NODE_DISABLE_COMPILE_CACHE=1 node scripts/format.mjs",
    "lint": "NODE_DISABLE_COMPILE_CACHE=1 node scripts/format.mjs --check"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.2",
